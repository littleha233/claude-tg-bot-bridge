# Telegram Bot token（来自 @BotFather）
BOT_TOKEN=123456:ABC-your-token-here

# 允许触发 cc 的 Telegram 用户 ID 白名单（逗号分隔）。
# 留空时，bot 不会执行任何 claude 任务，只响应 /whoami 帮你拿到自己的 ID。
ALLOWED_USER_IDS=

# cc 默认的工作目录（claude 在此目录下读写文件、执行命令）
WORK_DIR=/Users/meng

# claude 模型别名：opus / sonnet / haiku
MODEL=opus

# 权限模式：bypassPermissions(全自动) / acceptEdits / default
PERMISSION_MODE=bypassPermissions

# 触发前缀（消息以「cc:」或「cc：」开头即视为对 cc 说话）
TRIGGER=cc

# 访问 Telegram 的代理（国内必需）。HTTP 代理或 socks5；留空则直连
PROXY_URL=http://127.0.0.1:7890
